# Accounting Sync Environment Variables Template
# Copy these to your local.settings.json or Azure App Settings

# ==========================================
# ACCOUNTING SYNC CONFIGURATION
# ==========================================

# Enable/disable accounting sync
ACCOUNTING_SYNC_ENABLED=false

# Provider selection (currently: quickbooks)
ACCOUNTING_PROVIDER=quickbooks

# ==========================================
# QUICKBOOKS ONLINE CONFIGURATION
# ==========================================

# Company and environment
QBO_COMPANY_ID=
QBO_ENVIRONMENT=sandbox  # or production
QBO_REALM_ID=

# OAuth tokens (obtain via QuickBooks OAuth flow)
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=

# ==========================================
# STRIPE CONFIGURATION FOR PAYOUTS
# ==========================================

# Stripe API keys (already configured for payments)
# STRIPE_LIVE_SECRET_KEY=sk_live_...
# STRIPE_TEST_SECRET_KEY=sk_test_...

# Webhook secrets (per account for multi-account support)
# Format: acct_id1:whsec_xxx,acct_id2:whsec_yyy
STRIPE_WEBHOOK_SECRETS=

# Or use legacy single webhook secret (already configured)
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...

# Multi-account configuration (optional)
# Format: acct_id1:mode:secret_key,acct_id2:mode:secret_key
STRIPE_ACCOUNTS=

# ==========================================
# ACCOUNT MAPPINGS
# ==========================================

# Primary accounts (required)
ACCOUNTING_STRIPE_CLEARING_ACCOUNT=Stripe Clearing
ACCOUNTING_OPERATING_BANK_ACCOUNT=Operating Bank
ACCOUNTING_REVENUE_ACCOUNT=Revenue
ACCOUNTING_REFUNDS_ACCOUNT=Refunds
ACCOUNTING_STRIPE_FEE_ACCOUNT=Stripe Fees
ACCOUNTING_CHARGEBACK_ACCOUNT=Chargebacks
ACCOUNTING_ADJUSTMENT_ACCOUNT=Adjustments

# Revenue mapping by category (optional)
# Format: Category1:Account1,Category2:Account2
ACCOUNTING_REVENUE_MAPPING=

# Example:
# ACCOUNTING_REVENUE_MAPPING=General Giving:Revenue - Donations,Building Fund:Revenue - Building,Memorial:Revenue - Memorial

# ==========================================
# POSTING POLICY
# ==========================================

# Posting granularity: per-payout (default), per-day, per-transaction
ACCOUNTING_POSTING_GRANULARITY=per-payout

# Posting strategy: je-transfer (default), deposit
ACCOUNTING_POSTING_STRATEGY=je-transfer

# Date source: arrival (default), created
ACCOUNTING_POSTING_DATE_SOURCE=arrival

# Timezone for posting dates
ACCOUNTING_TIMEZONE=America/New_York

# Auto-create missing accounts (not recommended for production)
ACCOUNTING_AUTO_CREATE_ACCOUNTS=false

# ==========================================
# DIMENSION MAPPINGS (OPTIONAL)
# ==========================================

# Enable dimensions
ACCOUNTING_ENABLE_CLASS=false
ACCOUNTING_ENABLE_DEPARTMENT=false
ACCOUNTING_ENABLE_LOCATION=false

# Class mapping by category
# Format: Category1:ClassName1,Category2:ClassName2
ACCOUNTING_CLASS_MAPPING=

# Department mapping by category
# Format: Category1:DeptName1,Category2:DeptName2
ACCOUNTING_DEPARTMENT_MAPPING=

# ==========================================
# RETRY AND ERROR HANDLING
# ==========================================

# Maximum retry attempts on provider errors
ACCOUNTING_MAX_RETRY_ATTEMPTS=3

# Backoff time between retries (milliseconds)
ACCOUNTING_RETRY_BACKOFF_MS=5000

# Auto-reversal on payout.failed/canceled (not recommended)
ACCOUNTING_AUTO_REVERSAL=false

# ==========================================
# STORAGE WARNINGS (PRODUCTION)
# ==========================================

# Suppress in-memory storage warnings (for development only)
SUPPRESS_WEBHOOK_STORE_WARNING=false
SUPPRESS_SYNC_LEDGER_WARNING=false

# ⚠️ IMPORTANT FOR PRODUCTION:
# Replace in-memory storage with persistent storage:
# - Use Azure Table Storage, Cosmos DB, or SQL Database
# - Implement proper indexes and TTL policies
# - See PAYOUT_SYNC_SETUP.md for details
