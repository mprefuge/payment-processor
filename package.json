{
  "name": "payment-processing-function",
  "version": "1.0.0",
  "description": "Azure Function for payment processing with Stripe integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run start",
    "build": "tsc",
    "start": "func start",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run lint && npm run build && npm run test",
    "ci": "npm run verify",
    "test:unit": "vitest run",
    "setup:qbo": "ts-node scripts/setup-qbo-oauth.ts",
    "stripe:pi:success": "stripe trigger payment_intent.succeeded",
    "stripe:inv:paid": "stripe trigger invoice.paid",
    "stripe:inv:failed": "stripe trigger invoice.payment_failed",
    "stripe:refund:created": "stripe trigger refund.created",
    "stripe:payout:paid": "stripe trigger payout.paid",
    "stripe:payout:recon": "stripe trigger payout.reconciliation_completed"
  },
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "dependencies": {
    "@azure/data-tables": "^13.2.2",
    "@azure/functions": "^4.5.0",
    "@sendgrid/client": "^8.1.0",
    "@sendgrid/mail": "^8.1.0",
    "applicationinsights": "^3.12.0",
    "jsforce": "^3.10.7",
    "node-quickbooks": "^2.0.46",
    "stripe": "^14.7.0",
    "zod": "^3.23.8",
    "azure-functions-openapi": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "prettier": "^3.2.5"
  }
}
