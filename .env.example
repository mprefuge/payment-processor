# Azure Functions Configuration
FUNCTIONS_WORKER_RUNTIME=node
AzureWebJobsStorage=UseDevelopmentStorage=true

# Stripe Configuration
# Test mode keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret_here

# Live mode keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_LIVE_SECRET_KEY=sk_live_your_live_key_here
STRIPE_WEBHOOK_SECRET_LIVE=whsec_your_live_webhook_secret_here

# SendGrid Email Configuration
# Get API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email addresses (must be verified in SendGrid)
NOTIFICATION_EMAIL_FROM=noreply@example.com
NOTIFICATION_EMAIL_TEST=test@example.com
NOTIFICATION_EMAIL_LIVE=info@example.com

# Optional: Debug email (leave empty to disable debug emails)
DEBUG_EMAIL=

# Payment URLs
SUCCESS_URL=https://example.com/thankyou
CANCEL_URL=https://example.com/donate

# CRM Configuration (Optional - leave CRM_PROVIDER empty to disable)
CRM_PROVIDER=salesforce

# Salesforce Configuration (required if CRM_PROVIDER=salesforce)
SALESFORCE_USERNAME=your-salesforce-username@example.com
SALESFORCE_PASSWORD=your_salesforce_password
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Contact Matching Configuration (Optional - uses defaults if not set)
# Scoring thresholds
CONTACT_MATCH_THRESHOLD_HIGH=0.90
CONTACT_MATCH_THRESHOLD_LOW=0.60

# Scoring weights
CONTACT_MATCH_WEIGHT_EMAIL_EXACT=0.7
CONTACT_MATCH_WEIGHT_PHONE_EXACT=0.6
CONTACT_MATCH_WEIGHT_NAME_EXACT=0.5
CONTACT_MATCH_WEIGHT_NAME_FUZZY=0.35
CONTACT_MATCH_WEIGHT_ZIP_EXACT=0.2

# Normalization settings
CONTACT_MATCH_EMAIL_STRIP_PLUS_TAGS=true
CONTACT_MATCH_DEFAULT_COUNTRY_CODE=US
CONTACT_MATCH_NAME_FUZZY_THRESHOLD=0.8

# Transaction configuration
TRANSACTION_DEFAULT_CATEGORY=Uncategorized
TRANSACTION_NAME_TEMPLATE=Transaction - {category}

# Review task settings
CONTACT_MATCH_REVIEW_ENABLED=true
REVIEW_TASK_SUBJECT_PREFIX=Manual Review Required: 
REVIEW_DEEP_LINK_BASE_URL=https://example.com/admin

# Logging and observability
CONTACT_MATCH_LOG_LEVEL=info
CONTACT_MATCH_REDACT_PII=true
CONTACT_MATCH_STRUCTURED_LOGS=true

# Performance settings
CONTACT_MATCH_MAX_CANDIDATES=10
CONTACT_MATCH_SEARCH_TIMEOUT_MS=30000

# Production environment settings
NODE_ENV=development
# Set to true if you've implemented persistent idempotency storage
SUPPRESS_IDEMPOTENCY_WARNING=false
