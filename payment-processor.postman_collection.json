{
  "info": {
    "name": "Payment Processor API",
    "description": "Complete end-to-end test collection for the Payment Processor Azure Functions API.\n\nSet the `baseUrl` and `hostKey` collection variables before running.\n\n- `baseUrl`: e.g. `http://localhost:7075/api` (local) or `https://<func>.azurewebsites.net/api` (Azure)\n- `hostKey`: Azure Function host key (omit for anonymous endpoints)\n\nEndpoints tested:\n1. Health check\n2. Form Builder CRUD\n3. Form embed & Salesforce metadata\n4. Process transaction (checkout session)\n5. Stripe webhook\n6. Payout sync trigger\n7. Stripe true-up\n8. Manual QBO sync\n9. Salesforce payments sync\n10. QBO customers sync\n11. QBO receipts sync\n12. Salesforce record QBO sync\n13. Stripe duplicate check\n14. Test artifact cleanup\n15. OpenAPI docs & Swagger UI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "payment-processor-api-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:7075/api" },
    { "key": "hostKey", "value": "" },
    { "key": "configId", "value": "" },
    { "key": "sfContactId", "value": "0034x00001cRQs2AAG" }
  ],
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('status ok', () => pm.expect(j.status).to.eql('ok'));",
                  "pm.test('all connections healthy', () => {",
                  "  j.connections.forEach(c => pm.expect(c.healthy).to.be.true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
