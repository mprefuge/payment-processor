{
  "scriptFile": "../dist/src/app/oauthCallback/index.js",
  "entryPoint": "oauthCallbackHandler",
  "bindings": [
    {
      "authLevel": "anonymous",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": ["get"],
      "route": "oauth/callback"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "res"
    }
  ]
}
